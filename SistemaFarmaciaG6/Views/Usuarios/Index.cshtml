@model IEnumerable<SistemaFarmaciaG6.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";

    var categorias = Model
        .Select(x => x.IdCategoriaNavigation?.NombreCategoria)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var totalUsuarios = Model.Count();
}

<div class="container-fluid">

    <div class="categorias-section usuarios-header">

        <div class="usuarios-header-content">

            <div>
                <h2 class="mb-2">
                    Gestión de Usuarios
                </h2>

                <p class="mb-0 usuarios-subtitulo">
                    Administre, consulte y filtre las cuentas registradas en el sistema.
                </p>
            </div>

            <a asp-action="Create"
               class="btn btn-create usuarios-create-button">

                <i class="bi bi-person-plus me-2"></i>
                Crear Usuario

            </a>

        </div>

        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success mt-3 mb-0">
                <i class="bi bi-check-circle me-2"></i>
                @TempData["Exito"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-3 mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i>
                @TempData["Error"]
            </div>
        }

    </div>

    <div class="card shadow-sm filtros-usuarios-card mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-lg-5 col-md-12">

                    <label for="buscarUsuario"
                           class="form-label">

                        Buscar usuario

                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>

                        <input type="text"
                               id="buscarUsuario"
                               class="form-control"
                               placeholder="Nombre, cédula, correo, teléfono o departamento..." />

                    </div>

                </div>

                <div class="col-lg-3 col-md-6">

                    <label for="filtroEstado"
                           class="form-label">

                        Estado

                    </label>

                    <select id="filtroEstado"
                            class="form-select">

                        <option value="">
                            Todos los estados
                        </option>

                        <option value="Activo">
                            Activo
                        </option>

                        <option value="Inactivo">
                            Inactivo
                        </option>

                    </select>

                </div>

                <div class="col-lg-3 col-md-6">

                    <label for="filtroCategoria"
                           class="form-label">

                        Categoría

                    </label>

                    <select id="filtroCategoria"
                            class="form-select">

                        <option value="">
                            Todas las categorías
                        </option>

                        @foreach (var categoria in categorias)
                        {
                            <option value="@categoria">
                                @categoria
                            </option>
                        }

                    </select>

                </div>

                <div class="col-lg-1 col-md-12 d-flex align-items-end">

                    <button type="button"
                            id="limpiarFiltros"
                            class="btn btn-secondary w-100"
                            title="Limpiar filtros">

                        <i class="bi bi-arrow-counterclockwise"></i>

                    </button>

                </div>

            </div>

        </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

        <div class="usuarios-contador">

            <i class="bi bi-people me-1"></i>

            Registros encontrados:

            <strong id="contadorUsuarios">
                @totalUsuarios
            </strong>

        </div>

        <div class="text-muted small">
            Puede combinar búsqueda, estado y categoría.
        </div>

    </div>

    <div class="card shadow-sm usuarios-table-card">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 categorias-table usuarios-table">

                <thead>
                    <tr>
                        <th>Cédula</th>
                        <th>Nombre completo</th>
                        <th>Correo</th>
                        <th>Teléfono</th>
                        <th>Departamento</th>
                        <th>Categoría</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr class="fila-usuario">

                            <td class="fw-semibold">
                                @item.Cedula
                            </td>

                            <td>

                                <div class="usuario-nombre">

                                    <span class="usuario-avatar-tabla">

                                        @{
                                            string inicial =
                                            !string.IsNullOrWhiteSpace(item.Nombre)
                                            ? item.Nombre.Substring(0, 1).ToUpper()
                                            : "U";
                                        }

                                    @inicial

                                </span>

                                <div>

                                    <div class="fw-semibold">
                                        @item.Nombre
                                        @item.Apellido1
                                        @item.Apellido2
                                    </div>

                                    <small class="text-muted">
                                        Usuario #@item.IdUsuario
                                    </small>

                                </div>

                            </div>

                        </td>

                        <td>
                            <a href="mailto:@item.Correo"
                               class="usuario-correo">

                                @item.Correo

                            </a>
                        </td>

                        <td>
                            @(string.IsNullOrWhiteSpace(item.Telefono)
                                                        ? "No registrado"
                                                        : item.Telefono)
                                                                    </td>

                        <td>
                            @(item.IdDepartamentoNavigation?.NombreDepartamento
                                                        ?? "Sin departamento")
                                                                          </td>

                        <td class="categoria-usuario">

                            <span class="badge bg-light text-dark border">
                                @(item.IdCategoriaNavigation?.NombreCategoria
                                                                ?? "Sin categoría")
                            </span>

                            </td>

                            <td class="estado-usuario">

                            @if (item.Estado == "Activo")
                                {
                                    <span class="badge bg-success estado-badge">
                                        <i class="bi bi-check-circle me-1"></i>
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger estado-badge">
                                        <i class="bi bi-x-circle me-1"></i>
                                        Inactivo
                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-primary btn-sm">

                                    <i class="bi bi-pencil-square me-1"></i>
                                    Editar

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div id="sinResultadosUsuarios"
         class="alert alert-warning text-center mt-3 d-none">

        <i class="bi bi-search me-2"></i>

        No se encontraron usuarios que coincidan con los filtros seleccionados.

    </div>

</div>

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function () {

            const buscarUsuario =
                document.getElementById("buscarUsuario");

            const filtroEstado =
                document.getElementById("filtroEstado");

            const filtroCategoria =
                document.getElementById("filtroCategoria");

            const limpiarFiltros =
                document.getElementById("limpiarFiltros");

            const contadorUsuarios =
                document.getElementById("contadorUsuarios");

            const sinResultados =
                document.getElementById("sinResultadosUsuarios");

            function normalizarTexto(texto) {

                return (texto || "")
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .trim();

            }

            function filtrarUsuarios() {

                const texto =
                    normalizarTexto(buscarUsuario.value);

                const estado =
                    normalizarTexto(filtroEstado.value);

                const categoria =
                    normalizarTexto(filtroCategoria.value);

                const filas =
                    document.querySelectorAll(".fila-usuario");

                let visibles = 0;

                filas.forEach(function (fila) {

                    const contenido =
                        normalizarTexto(fila.innerText);

                    const estadoFila =
                        normalizarTexto(
                            fila.querySelector(".estado-usuario")?.innerText
                        );

                    const categoriaFila =
                        normalizarTexto(
                            fila.querySelector(".categoria-usuario")?.innerText
                        );

                    const coincideTexto =
                        texto === "" ||
                        contenido.includes(texto);

                    const coincideEstado =
                        estado === "" ||
                        estadoFila.includes(estado);

                    const coincideCategoria =
                        categoria === "" ||
                        categoriaFila.includes(categoria);

                    const mostrar =
                        coincideTexto &&
                        coincideEstado &&
                        coincideCategoria;

                    fila.style.display =
                        mostrar ? "" : "none";

                    if (mostrar) {
                        visibles++;
                    }

                });

                contadorUsuarios.textContent = visibles;

                sinResultados.classList.toggle(
                    "d-none",
                    visibles > 0
                );

            }

            buscarUsuario.addEventListener(
                "input",
                filtrarUsuarios
            );

            filtroEstado.addEventListener(
                "change",
                filtrarUsuarios
            );

            filtroCategoria.addEventListener(
                "change",
                filtrarUsuarios
            );

            limpiarFiltros.addEventListener(
                "click",
                function () {

                    buscarUsuario.value = "";
                    filtroEstado.value = "";
                    filtroCategoria.value = "";

                    buscarUsuario.focus();

                    filtrarUsuarios();

                }
            );

        });

    </script>

}