<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Facultad Farmacia</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="icon" type="image/png" href="~/images/favicon_farmacia.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Facultad_Farmacia.styles.css" asp-append-version="true" />
</head>


    <body>

    @{
        string nombreUsuario = Context.Session.GetString("Nombre") ?? "";
        string rolUsuario = Context.Session.GetString("Rol") ?? "";
    }

    <div class="ucr-bar">

        <a href="https://www.ucr.ac.cr"
           target="_blank"
           class="ucr-link">
            UNIVERSIDAD DE COSTA RICA
        </a>

        <a href="https://farmacia.ucr.ac.cr/"
           target="_blank"
           class="ucr-logo-link">

            <img src="~/images/Farmacia_logo.png"
                 alt="Logo UCR"
                 class="ucr-logo" />

        </a>

    </div>

    <div class="user-menu">

        <span class="user-name">
            @nombreUsuario
        </span>

        <span class="separator">|</span>

        @if (!string.IsNullOrEmpty(rolUsuario))
        {
            <span class="user-role">
                @rolUsuario
            </span>
        }

        <a asp-controller="Perfil"
           asp-action="Index">
            Mi Perfil
        </a>

        <a asp-controller="Account"
           asp-action="Logout">
            Cerrar Sesión
        </a>

    </div>

        <header>

            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light navbar-teal border-bottom box-shadow">

                <div class="container-fluid">

                    <button class="navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target=".navbar-collapse">

                        <span class="navbar-toggler-icon"></span>

                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        <ul class="navbar-nav flex-grow-1">

                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Home
                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Categorias"
                                   asp-action="Index">
                                    Categorías
                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Usuarios"
                                   asp-action="Index">
                                    Usuarios
                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Roles"
                                   asp-action="Index">
                                    Roles
                                </a>

                            </li>

                        </ul>

                    </div>

                </div>

            </nav>

        </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">

        <div class="footer-content">

            © 2026 Facultad de Farmacia -
            Tel. 2511-8350 |
            Correo: recepción.farmacia@ucr.ac.cr |
            <a href="#">
                Contáctenos
            </a>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>