<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]  Facultad Farmacia</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="icon" type="image/png" href="~/images/favicon_farmacia.png" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Facultad_Farmacia.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="top-bar">
        <div class="top-bar-left">
            <a href="#" title="Telefono"><i class="bi bi-telephone"></i></a>+506 2208-8989
        </div>
        <div class="top-bar-right">
            <a href="#" title="Facebook"><i class="bi bi-facebook"></i></a>
            <a href="#" title="Instagram"><i class="bi bi-instagram"></i></a>
            <a href="#" title="YouTube"><i class="bi bi-youtube"></i></a>
            <span>| Facultad Farmacia | EN</span>
        </div>
    </div>
    <header>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light navbar-teal border-bottom box-shadow mb-3">

            <div class="container-fluid">


                <div class="logo-section d-flex align-items-center">

                    <a asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo_farmacia.png" alt="Logo Facultad de Farmacia" class="logo-img me-3" />
                    </a>
                </div>

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link " asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Categorias" asp-action="Index">Categorias</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">

            <div class="footer-logo d-flex align-items-center">
                <img src="~/images/logo_farmacia.png" alt="Logo Facultad de Farmacia" class="footer-img me-2" />
                &copy; 2026 - Facultad Farmacia - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
