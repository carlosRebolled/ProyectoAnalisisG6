@{
    Layout = null;
    ViewData["Title"] = "Inicio de Sesión";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Facultad_Farmacia.styles.css" asp-append-version="true" />
</head>
<body>

    <div class="ucr-bar">

        <a href="https://www.ucr.ac.cr"
           target="_blank"
           class="ucr-link">
            UNIVERSIDAD DE COSTA RICA
        </a>

        <a href="https://www.ucr.ac.cr"
           target="_blank"
           class="ucr-logo-link">

            <img src="~/images/Farmacia_logo.png"
                 alt="Logo UCR"
                 class="ucr-logo" />

        </a>

    </div>

<div class="login-wrapper">
    <div class="card login-card shadow-sm">
        <div class="card-header text-center login-header">
                <img src="~/images/Farmacia_logo.png"
                     alt="Logo Facultad de Farmacia"
                     class="login-logo me-2" />
            <h4>Inicio de Sesión</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Correo</label>
                    <input type="email"
                           name="correo"
                           class="form-control form-control-sm"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input type="password"
                           name="contrasena"
                           class="form-control form-control-sm"
                           required />
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Ingresar
                </button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }
        </div>
    </div>
</div>
    <footer class="footer-custom">

        <div class="footer-content">

            © 2026 Facultad de Farmacia -
            Tel. 2511-8350 |
            Correo: recepción.farmacia@ucr.ac.cr |
            <a href="#" class="footer-link">
                Contáctenos
            </a>

        </div>

    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>