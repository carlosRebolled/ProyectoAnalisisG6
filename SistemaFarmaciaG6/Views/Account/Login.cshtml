@{
    Layout = null;
    ViewData["Title"] = "Inicio de Sesión";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Facultad_Farmacia.styles.css" asp-append-version="true" />
</head>
<body>

    <div class="top-bar">
        <div class="top-bar-left">
            <a href="#" title="Telefono">
                <i class="bi bi-telephone"></i>
            </a>
            +506 2208-8989
        </div>

        <div class="top-bar-right">
            <a href="#" title="Facebook">
                <i class="bi bi-facebook"></i>
            </a>

            <a href="#" title="Instagram">
                <i class="bi bi-instagram"></i>
            </a>

            <a href="#" title="YouTube">
                <i class="bi bi-youtube"></i>
            </a>

            <span>| Facultad Farmacia | EN</span>
        </div>
    </div>

<div class="login-wrapper">
    <div class="card login-card shadow-sm">
        <div class="card-header text-center login-header">
                <img src="~/images/logo_farmacia.png"
                     alt="Logo Facultad de Farmacia"
                     class="footer-img me-2" />
            <h4>Inicio de Sesión</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Correo</label>
                    <input type="email"
                           name="correo"
                           class="form-control form-control-sm"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input type="password"
                           name="contrasena"
                           class="form-control form-control-sm"
                           required />
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Ingresar
                </button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }
        </div>
    </div>
</div>
    <footer class="border-top footer text-muted">

        <div class="container">

            <div class="footer-logo d-flex align-items-center">

                <img src="~/images/logo_farmacia.png"
                     alt="Logo Facultad de Farmacia"
                     class="footer-img me-2" />

                &copy; 2026 - Facultad Farmacia -
                <a asp-controller="Home"
                   asp-action="">
                    Privacy
                </a>

            </div>

        </div>

    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>