@{
    ViewData["Title"] = "Inicio de Sesión";
}

<h2>Inicio de Sesión</h2>

<form method="post">

    <div class="mb-3">
        <label>Correo</label>
        <input type="email"
               name="correo"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label>Contraseña</label>
        <input type="password"
               name="contrasena"
               class="form-control"
               required />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Ingresar
    </button>

</form>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mt-3">
        @ViewBag.Error
    </div>
}