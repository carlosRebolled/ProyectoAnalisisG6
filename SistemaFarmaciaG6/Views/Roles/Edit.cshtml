@model SistemaFarmaciaG6.Models.Usuario

<h2>Cambiar Rol</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.IdUsuario" />

    <div class="mb-3">
        <label>Usuario</label>
        <input class="form-control"
               value="@Model.Nombre @Model.Apellido1 @Model.Apellido2"
               readonly />
    </div>

    <div class="mb-3">
        <label>Correo</label>
        <input class="form-control"
               value="@Model.Correo"
               readonly />
    </div>

    <div class="mb-3">
        <label>Rol</label>
        <select name="idRol" asp-items="ViewBag.Roles" class="form-select">
            <option value="">Seleccione un rol</option>
        </select>
    </div>

    <button type="submit" class="btn btn-warning">
        Guardar Rol
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Volver
    </a>
</form>