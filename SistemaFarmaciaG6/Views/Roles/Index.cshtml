@model IEnumerable<SistemaFarmaciaG6.Models.Usuario>

@{
    ViewData["Title"] = "Roles";
}

<div class="container-fluid">

    <div class="categorias-section">

        <h2 class="mb-3">
            Gestión de Roles
        </h2>

        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success">
                @TempData["Exito"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

    </div>

    <div class="row mb-4">

        <div class="col-md-4">

            <label class="form-label">
                Buscar por usuario o correo
            </label>

            <input type="text"
                   id="buscarRol"
                   class="form-control"
                   placeholder="Escriba para buscar..." />

        </div>

        <div class="col-md-4">

            <label class="form-label">
                Filtrar por Rol
            </label>

            <select id="filtroRol" class="form-select">

                <option value="">Todos</option>
                <option value="Administrador">Administrador</option>
                <option value="Docente">Docente</option>
                <option value="Director">Director</option>
                <option value="Decano">Decano</option>
                <option value="Jefatura">Jefatura</option>
                <option value="Visualizador">Visualizador</option>

            </select>

        </div>

    </div>

    <table class="table table-hover shadow-sm categorias-table">

        <thead>

            <tr>
                <th>Usuario</th>
                <th>Correo</th>
                <th>Rol Actual</th>
                <th></th>
            </tr>

        </thead>

        <tbody>

            @foreach (var usuario in Model)
            {
                <tr class="fila-rol">

                    <td>
                        @usuario.Nombre
                        @usuario.Apellido1
                        @usuario.Apellido2
                    </td>

                    <td>
                        @usuario.Correo
                    </td>

                    <td class="rol-usuario">

                        @(usuario.UsuarioRols.FirstOrDefault()?.IdRolNavigation?.NombreRol ?? "Sin rol")

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@usuario.IdUsuario"
                           class="btn btn-primary btn-sm">
                            Cambiar Rol
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

@section Scripts {

    <script>

        document.getElementById("buscarRol").addEventListener("keyup", filtrarRoles);
        document.getElementById("filtroRol").addEventListener("change", filtrarRoles);

        function filtrarRoles()
        {
            let texto = document.getElementById("buscarRol").value.toLowerCase();
            let rol = document.getElementById("filtroRol").value.toLowerCase();

            let filas = document.querySelectorAll(".fila-rol");

            filas.forEach(function (fila) {

                let contenido = fila.innerText.toLowerCase();

                let rolFila = fila.querySelector(".rol-usuario")
                                  .innerText
                                  .trim()
                                  .toLowerCase();

                let coincideTexto = contenido.includes(texto);

                let coincideRol =
                    rol === "" ||
                    rolFila === rol;

                fila.style.display =
                    coincideTexto && coincideRol
                    ? ""
                    : "none";
            });
        }

    </script>

}
