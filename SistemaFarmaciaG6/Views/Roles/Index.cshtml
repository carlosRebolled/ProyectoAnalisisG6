@model IEnumerable<SistemaFarmaciaG6.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Roles";

    var totalUsuarios = Model.Count();

    var rolesDisponibles = new[]
    {
        "Administrador",
        "Docente",
        "Director",
        "Decano",
        "Jefatura",
        "Visualizador"
    };
}

<div class="container-fluid">

    <div class="categorias-section roles-header">

        <div class="roles-header-content">

            <div>

                <h2 class="mb-2">
                    Gestión de Roles
                </h2>

                <p class="mb-0 roles-subtitulo">
                    Consulte y modifique los permisos asignados a cada usuario del sistema.
                </p>

            </div>

        </div>

        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success mt-3 mb-0">

                <i class="bi bi-check-circle me-2"></i>

                @TempData["Exito"]

            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-3 mb-0">

                <i class="bi bi-exclamation-triangle me-2"></i>

                @TempData["Error"]

            </div>
        }

    </div>

    <div class="card shadow-sm filtros-roles-card mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-lg-6 col-md-12">

                    <label for="buscarRol"
                           class="form-label">

                        Buscar usuario

                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>

                        <input type="text"
                               id="buscarRol"
                               class="form-control"
                               placeholder="Nombre, correo o rol..." />

                    </div>

                </div>

                <div class="col-lg-5 col-md-9">

                    <label for="filtroRol"
                           class="form-label">

                        Filtrar por rol

                    </label>

                    <select id="filtroRol"
                            class="form-select">

                        <option value="">
                            Todos los roles
                        </option>

                        @foreach (var rol in rolesDisponibles)
                        {
                            <option value="@rol">
                                @rol
                            </option>
                        }

                        <option value="Sin rol">
                            Sin rol
                        </option>

                    </select>

                </div>

                <div class="col-lg-1 col-md-3 d-flex align-items-end">

                    <button type="button"
                            id="limpiarFiltros"
                            class="btn btn-secondary w-100"
                            title="Limpiar filtros">

                        <i class="bi bi-arrow-counterclockwise"></i>

                    </button>

                </div>

            </div>

        </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

        <div class="roles-contador">

            <i class="bi bi-person-badge me-1"></i>

            Usuarios encontrados:

            <strong id="contadorRoles">
                @totalUsuarios
            </strong>

        </div>

        <div class="text-muted small">
            Puede combinar la búsqueda con el filtro por rol.
        </div>

    </div>

    <div class="card shadow-sm roles-table-card">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 categorias-table roles-table">

                <thead>

                    <tr>
                        <th>Usuario</th>
                        <th>Correo</th>
                        <th>Rol actual</th>
                        <th class="text-center">Acciones</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var usuario in Model)
                    {
                        var nombreRol =
                        usuario.UsuarioRols
                        .FirstOrDefault()?
                        .IdRolNavigation?
                        .NombreRol
                        ?? "Sin rol";

                        string claseRol = nombreRol switch
                        {
                            "Administrador" => "bg-danger",
                            "Docente" => "bg-primary",
                            "Director" => "bg-warning text-dark",
                            "Decano" => "bg-success",
                            "Jefatura" => "bg-info text-dark",
                            "Visualizador" => "bg-secondary",
                            _ => "bg-dark"
                        };

                        <tr class="fila-rol">

                            <td>

                                <div class="rol-usuario-info">

                                    <span class="rol-avatar">

                                        @{
                                            string inicial =
                                            !string.IsNullOrWhiteSpace(usuario.Nombre)
                                            ? usuario.Nombre.Substring(0, 1).ToUpper()
                                            : "U";
                                        }

                                        @inicial

                                    </span>

                                    <div>

                                        <div class="fw-semibold">

                                            @usuario.Nombre
                                            @usuario.Apellido1
                                            @usuario.Apellido2

                                        </div>

                                        <small class="text-muted">
                                            Usuario #@usuario.IdUsuario
                                        </small>

                                    </div>

                                </div>

                            </td>

                            <td>

                                <a href="mailto:@usuario.Correo"
                                   class="rol-correo">

                                    @usuario.Correo

                                </a>

                            </td>

                            <td class="rol-usuario">

                                <span class="badge @claseRol rol-badge">
                                    @nombreRol
                                </span>

                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@usuario.IdUsuario"
                                   class="btn btn-primary btn-sm">

                                    <i class="bi bi-person-gear me-1"></i>
                                    Cambiar Rol

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div id="sinResultadosRoles"
         class="alert alert-warning text-center mt-3 d-none">

        <i class="bi bi-search me-2"></i>

        No se encontraron usuarios que coincidan con los filtros seleccionados.

    </div>

</div>

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function () {

            const buscarRol =
                document.getElementById("buscarRol");

            const filtroRol =
                document.getElementById("filtroRol");

            const limpiarFiltros =
                document.getElementById("limpiarFiltros");

            const contadorRoles =
                document.getElementById("contadorRoles");

            const sinResultados =
                document.getElementById("sinResultadosRoles");

            function normalizarTexto(texto) {

                return (texto || "")
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .trim();

            }

            function filtrarRoles() {

                const texto =
                    normalizarTexto(buscarRol.value);

                const rolSeleccionado =
                    normalizarTexto(filtroRol.value);

                const filas =
                    document.querySelectorAll(".fila-rol");

                let visibles = 0;

                filas.forEach(function (fila) {

                    const contenido =
                        normalizarTexto(fila.innerText);

                    const rolFila =
                        normalizarTexto(
                            fila.querySelector(".rol-usuario")?.innerText
                        );

                    const coincideTexto =
                        texto === "" ||
                        contenido.includes(texto);

                    const coincideRol =
                        rolSeleccionado === "" ||
                        rolFila === rolSeleccionado;

                    const mostrar =
                        coincideTexto &&
                        coincideRol;

                    fila.style.display =
                        mostrar ? "" : "none";

                    if (mostrar) {
                        visibles++;
                    }

                });

                contadorRoles.textContent = visibles;

                sinResultados.classList.toggle(
                    "d-none",
                    visibles > 0
                );

            }

            buscarRol.addEventListener(
                "input",
                filtrarRoles
            );

            filtroRol.addEventListener(
                "change",
                filtrarRoles
            );

            limpiarFiltros.addEventListener(
                "click",
                function () {

                    buscarRol.value = "";
                    filtroRol.value = "";

                    buscarRol.focus();

                    filtrarRoles();

                }
            );

        });

    </script>

}