@{
    ViewData["Title"] = "Dashboard Director";
}

<div class="container-fluid">
    <div class="categorias-section">
        <h2 class="mb-3">Dashboard Director</h2>
    </div>

    <div class="row mt-4">
        <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><h6>Total Informes</h6><h2>@ViewBag.Total</h2></div></div></div>
        <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><h6>Pendientes</h6><h2>@ViewBag.Pendientes</h2></div></div></div>
        <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><h6>Devueltos</h6><h2>@ViewBag.Devueltos</h2></div></div></div>
        <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><h6>Aprobados</h6><h2>@ViewBag.Aprobados</h2></div></div></div>
    </div>

    <a asp-controller="InformeDocente" asp-action="Index" class="btn btn-primary">
        Revisar informes
    </a>

    <a asp-controller="InformeDepartamental" asp-action="Index" class="btn btn-secondary">
        Informe departamental
    </a>
</div>