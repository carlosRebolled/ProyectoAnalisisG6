@model IEnumerable<SistemaFarmaciaG6.Models.Auditorium>

@{
    ViewData["Title"] = "Bitácora";
}

<div class="container-fluid">

    <div class="categorias-section">

        <h2 class="mb-3">
            Bitácora del Sistema
        </h2>

    </div>

    <div class="row mb-4">

        <div class="col-md-4">

            <label class="form-label">
                Buscar por usuario
            </label>

            <input type="text"
                   id="buscarUsuario"
                   class="form-control"
                   placeholder="Escriba el nombre del usuario..." />

        </div>

    </div>

    <table class="table table-hover shadow-sm categorias-table">

        <thead>
            <tr>
                <th>Fecha</th>
                <th>Usuario</th>
                <th>Tabla</th>
                <th>Acción</th>
                <th>Descripción</th>
                <th>IP</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr class="fila-auditoria">

                    <td>
                        @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                    </td>

                    <td class="nombre-usuario">
                        @item.IdUsuarioNavigation.Nombre
                        @item.IdUsuarioNavigation.Apellido1
                    </td>

                    <td>
                        @item.TablaAfectada
                    </td>

                    <td>
                        <span class="badge bg-primary">
                            @item.Accion
                        </span>
                    </td>

                    <td>
                        @item.Descripcion
                    </td>

                    <td>
                        @item.IpEquipo
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

@section Scripts {

    <script>

        document.getElementById("buscarUsuario")
        .addEventListener("keyup", function () {

            let texto = this.value.toLowerCase();

            let filas = document.querySelectorAll(".fila-auditoria");

            filas.forEach(function (fila) {

                let nombre = fila.querySelector(".nombre-usuario")
                                 .innerText
                                 .toLowerCase();

                fila.style.display =
                    nombre.includes(texto)
                    ? ""
                    : "none";

            });

        });

    </script>

}

