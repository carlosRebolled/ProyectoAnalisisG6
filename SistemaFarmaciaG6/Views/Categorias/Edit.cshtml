@model SistemaFarmaciaG6.Models.Categoria
@{
    ViewData["Title"] = "Editar Categoria";
}
<h2>Editar Categoría</h2>
<p>

    <a asp-action="Index" class="btn btn-details"> Volver al listado</a>
</p>
<form asp-action="Edit">
    <input type="hidden" asp-for="IdCategoria" />
    <div class="form-group">
        <label asp-for="NombreCategoria"></label>
        <input asp-for="NombreCategoria" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Estado"></label>
        <input asp-for="Estado" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Actualizar</button>
   
</form>
