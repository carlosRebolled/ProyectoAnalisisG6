@model SistemaFarmaciaG6.Models.InformeDireccion

@{
    ViewData["Title"] = "Crear Informe de Dirección";
}

<div class="container mt-4">

    <h2 class="mb-4">
        Crear Informe de Dirección
    </h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">
            @TempData["Exito"]
        </div>
    }

    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <div class="card shadow-sm mb-4">

            <div class="card-header bg-secondary text-white">
                1. Información general
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="fw-bold">
                            Departamento
                        </label>

                        <input class="form-control"
                               readonly
                               value="@ViewBag.Departamento" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="fw-bold">
                            Año
                        </label>

                        <input class="form-control"
                               readonly
                               value="@ViewBag.Anio" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="fw-bold">
                            Director
                        </label>

                        <input class="form-control"
                               readonly
                               value="@ViewBag.NombreDirector" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="fw-bold">
                            Correo
                        </label>

                        <input class="form-control"
                               readonly
                               value="@ViewBag.Correo" />

                    </div>

                </div>

            </div>

        </div>

        <div class="card shadow-sm mb-4">

            <div class="card shadow-sm mb-4">

                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">
                        2. Reuniones del Departamento
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-4">

                            <label class="fw-bold">
                                Número de sesión
                            </label>

                            <input type="text"
                                   class="form-control"
                                   name="NumeroSesion" />

                        </div>

                        <div class="col-md-4">

                            <label class="fw-bold">
                                Fecha
                            </label>

                            <input type="date"
                                   class="form-control"
                                   name="FechaSesion" />

                        </div>

                    </div>

                    <div class="mt-3">

                        <label class="fw-bold">
                            Puntos vistos
                        </label>

                        <textarea class="form-control"
                                  rows="4"
                                  name="PuntosVistos"></textarea>

                    </div>

                </div>

            </div>

        </div>
        
        <hr />

        <h4 class="mt-4 mb-3">

            Cursos del Departamento

        </h4>

        <div id="contenedorCursos">

            <div class="card shadow-sm mb-4">

                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">
                        Curso #1
                    </h5>

                    <button type="button"
                            class="btn btn-danger btn-sm btnEliminarCurso">
                        Eliminar
                    </button>

                </div>

                <div class="card-body">

                    
                    <div class="card shadow-sm mb-4">

                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">
                                Actividades de los Cursos
                            </h5>
                        </div>

                        <div class="card-body">

                            <div class="card border mb-4">

                                <div class="card-header">
                                    Curso
                                </div>

                                <div class="card-body">

                                    <div class="row mb-4">

                                        <div class="col-md-12">

                                            <label class="fw-bold">
                                                Nombre del curso
                                            </label>

                                            <select class="form-select"
                                                    name="IdCurso[]">

                                                <option value="">
                                                    Seleccione un curso
                                                </option>

                                                @foreach (var curso in ViewBag.Cursos)
                                                {
                                                    <option value="@curso.IdCurso">
                                                        @curso.SiglaCurso - @curso.NombreCurso
                                                    </option>
                                                }

                                            </select>

                                        </div>

                                    </div>
                                    <div class="row mb-3">
                                        <label class="fw-bold">
                                            Coordinación
                                        </label>
                                        <div class="col-md-2">

                                

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="CoordinacionCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="CoordinacionDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">
                                        <label class="fw-bold">
                                            Colaboradores
                                        </label>

                                        <div class="col-md-2">

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="ColaboradoresCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="ColaboradoresDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">

                                        <label class="fw-bold">
                                            Invitados
                                        </label>

                                        <div class="col-md-2">

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="InvitadosCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="InvitadosDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">

                                        <label class="fw-bold">
                                            Experiencias prácticas
                                        </label>

                                        <div class="col-md-2">

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="ExperienciasPracticasCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="ExperienciasPracticasDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">

                                        <label class="fw-bold">
                                            Actividades de docencia integradas en proyectos de Investigación y Acción Social
                                        </label>

                                        <div class="col-md-2">

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="ActividadesDocenciaIntegradasCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="ActividadesDocenciaIntegradasDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">

                                        <label class="fw-bold">
                                            Actividades donde se participa en el análisis y estudio de problemas del contexto
                                        </label>

                                        <div class="col-md-2">

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="ActividadesAnalisisContextoCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="ActividadesAnalisisContextoDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">

                                        <label class="fw-bold">
                                            Tecnicas didácticas
                                        </label>

                                        <div class="col-md-2">

                                            <label>Cantidad</label>

                                            <input type="number"
                                                   class="form-control"
                                                   name="TecnicasDidacticasCantidad[]" />

                                        </div>

                                        <div class="col-md-10">

                                            <label>Detalle</label>

                                            <textarea class="form-control"
                                                      rows="2"
                                                      name="TecnicasDidacticasDetalle[]"></textarea>

                                        </div>

                                    </div>

                                    <div class="row mb-3">

                                        <label class="fw-bold">
                                            Asistentes del Curso
                                        </label>

                                        <div class="col-md-2">

                                            <input type="number"
                                                   min="0"
                                                   class="form-control"
                                                   name="AsistentesCurso[]" />

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <div class="text-end mb-4">

                            <button type="button"
                                    id="btnAgregarCurso"
                                    class="btn btn-success">

                                + Agregar otro curso

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                Observaciones del Director
            </div>
            <div class="card-body">
                <textarea asp-for="ObservacionesDirector"
                          class="form-control"
                          rows="6"></textarea>
            </div>
        </div>

        <div class="text-center">

        <button type="submit" class="btn btn-create">
            Guardar Informe
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Volver
        </a>

        </div>
    </form>
</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        const boton = document.getElementById("btnAgregarCurso");

        const contenedor = document.getElementById("contenedorCursos");

        const cursoBase = document.querySelector("#contenedorCursos .card");

        boton.addEventListener("click", function () {

            let copia = cursoBase.cloneNode(true);
            
            let numero = contenedor.children.length + 1;
            
            copia.querySelector(".card-header h5").innerText = "Curso #" + numero;

            copia.querySelectorAll("input").forEach(x => {

                if (x.type != "hidden")
                    x.value = "";

            });

            copia.querySelectorAll("textarea")
                .forEach(x => x.value = "");

            copia.querySelectorAll("select")
                .forEach(x => x.selectedIndex = 0);

            contenedor.appendChild(copia);

        });

    });

</script>