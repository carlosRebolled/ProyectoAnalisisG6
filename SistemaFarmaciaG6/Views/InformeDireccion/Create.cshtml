@model SistemaFarmaciaG6.Models.InformeDireccion

@{
    ViewData["Title"] = "Crear Informe Dirección";
}

<div class="container-fluid">

    <div class="categorias-section">
        <h2 class="mb-3">Crear Informe de Dirección</h2>
    </div>

    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Observaciones del Director</label>
            <textarea asp-for="ObservacionesDirector"
                      class="form-control"
                      rows="6"
                      placeholder="Ingrese observaciones generales del informe de dirección"></textarea>
        </div>

        <button type="submit" class="btn btn-create">
            Guardar Informe
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Volver
        </a>

    </form>

</div>