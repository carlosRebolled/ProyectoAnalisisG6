@model SistemaFarmaciaG6.Models.InformeDireccion

@{
    ViewData["Title"] = "Detalle del Informe de Dirección";
}

<div class="container-fluid">

    <div class="categorias-section">

        <h2 class="mb-3">
            Detalle del Informe de Dirección
        </h2>

    </div>

    <div class="card shadow-sm mb-4">

        <div class="card-header d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                Informe de Dirección @Model.Anio
            </h4>

            @if (Model.IdEstado == 1)
            {
                <span class="badge bg-secondary">
                    Borrador
                </span>
            }
            else if (Model.IdEstado == 2)
            {
                <span class="badge bg-warning text-dark">
                    Pendiente de revisión
                </span>
            }
            else if (Model.IdEstado == 3)
            {
                <span class="badge bg-danger">
                    Devuelto
                </span>
            }
            else if (Model.IdEstado == 4)
            {
                <span class="badge bg-success">
                    Aprobado
                </span>
            }
            else if (Model.IdEstado == 5)
            {
                <span class="badge bg-primary">
                    Finalizado
                </span>
            }
            else
            {
                <span class="badge bg-secondary">
                    @Model.IdEstadoNavigation?.NombreEstado
                </span>
            }

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="fw-bold">
                        Director
                    </label>

                    <input class="form-control"
                           readonly
                           value="@($"{Model.IdUsuarioNavigation.Nombre} {Model.IdUsuarioNavigation.Apellido1} {Model.IdUsuarioNavigation.Apellido2}")" />

                </div>

                <div class="col-md-6 mb-3">

                    <label class="fw-bold">
                        Departamento
                    </label>

                    <input class="form-control"
                           readonly
                           value="@Model.IdUsuarioNavigation.IdDepartamentoNavigation?.NombreDepartamento" />

                </div>

                <div class="col-md-4 mb-3">

                    <label class="fw-bold">
                        Año
                    </label>

                    <input class="form-control"
                           readonly
                           value="@Model.Anio" />

                </div>

                <div class="col-md-4 mb-3">

                    <label class="fw-bold">
                        Fecha de creación
                    </label>

                    <input class="form-control"
                           readonly
                           value="@Model.FechaCreacion.ToString("dd/MM/yyyy")" />

                </div>

                <div class="col-md-4 mb-3">

                    <label class="fw-bold">
                        Fecha de envío
                    </label>

                    <input class="form-control"
                           readonly
                           value="@(Model.FechaEnvio?.ToString("dd/MM/yyyy HH:mm") ?? "No enviado")" />

                </div>

                <div class="col-md-4 mb-3">

                    <label class="fw-bold">
                        Fecha de aprobación
                    </label>

                    <input class="form-control"
                           readonly
                           value="@(Model.FechaAprobacion?.ToString("dd/MM/yyyy HH:mm") ?? "No aprobado")" />

                </div>

            </div>

        </div>

    </div>

    <hr />

    <h4 class="mb-3">
        Reuniones de Departamento
    </h4>

    @if (Model.SesionesDepartamentos != null && Model.SesionesDepartamentos.Any())
    {
        @foreach (var reunion in Model.SesionesDepartamentos.OrderBy(x => x.FechaSesion))
        {
            <div class="card shadow-sm mb-3">

                <div class="card-header bg-secondary text-white">
                    Sesión @reunion.NumeroSesion
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3 mb-3">

                            <label class="fw-bold">
                                Número de Sesión
                            </label>

                            <input class="form-control"
                                   readonly
                                   value="@reunion.NumeroSesion" />

                        </div>

                        <div class="col-md-3 mb-3">

                            <label class="fw-bold">
                                Fecha
                            </label>

                            <input class="form-control"
                                   readonly
                                   value="@reunion.FechaSesion.ToString("dd/MM/yyyy")" />

                        </div>

                        <div class="col-md-6 mb-3">

                            <label class="fw-bold">
                                Puntos Vistos
                            </label>

                            <textarea class="form-control"
                                      rows="3"
                                      readonly>@reunion.PuntosVistos</textarea>

                        </div>

                    </div>

                </div>

            </div>
        }
    }
    else
    {
        <div class="alert alert-secondary">
            No existen reuniones registradas.
        </div>
    }

    <hr />

    <h4 class="mb-3">
        Cursos impartidos por el Departamento
    </h4>

    @foreach (var curso in Model.CursosDireccions)
    {
        <div class="card shadow-sm mb-4">

            <div class="card-header bg-secondary text-white">

                <strong>
                    @curso.IdCursoNavigation?.SiglaCurso -
                    @curso.IdCursoNavigation?.NombreCurso
                </strong>

            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-bordered">

                        <thead class="table-light">

                            <tr>
                                <th>Actividad</th>
                                <th style="width:120px;">Cantidad</th>
                                <th>Detalle</th>
                            </tr>

                        </thead>

                        <tbody>

                            <tr>
                                <td>Coordinación</td>
                                <td>@curso.CoordinacionCantidad</td>
                                <td>@curso.CoordinacionDetalle</td>
                            </tr>

                            <tr>
                                <td>Colaboradores</td>
                                <td>@curso.ColaboradoresCantidad</td>
                                <td>@curso.ColaboradoresDetalle</td>
                            </tr>

                            <tr>
                                <td>Invitados</td>
                                <td>@curso.InvitadosCantidad</td>
                                <td>@curso.InvitadosDetalle</td>
                            </tr>

                            <tr>
                                <td>Experiencias Prácticas</td>
                                <td>@curso.ExperienciasPracticasCantidad</td>
                                <td>@curso.ExperienciasPracticasDetalle</td>
                            </tr>

                            <tr>
                                <td>Actividades de Docencia Integradas</td>
                                <td>@curso.ActividadesDocenciaIntegradasCantidad</td>
                                <td>@curso.ActividadesDocenciaIntegradasDetalle</td>
                            </tr>

                            <tr>
                                <td>Actividades de Análisis de Contexto</td>
                                <td>@curso.ActividadesAnalisisContextoCantidad</td>
                                <td>@curso.ActividadesAnalisisContextoDetalle</td>
                            </tr>

                            <tr>
                                <td>Técnicas Didácticas</td>
                                <td>@curso.TecnicasDidacticasCantidad</td>
                                <td>@curso.TecnicasDidacticasDetalle</td>
                            </tr>

                            <tr>
                                <td>Asistentes al curso</td>
                                <td colspan="2">
                                    @curso.AsistentesCurso
                                </td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    }

    <hr />

    <div class="card border-info mb-3">

        <div class="card-header bg-info text-white">
            Observaciones del Director
        </div>

        <div class="card-body">

            @if (string.IsNullOrWhiteSpace(Model.ObservacionesDirector))
            {
                <span class="text-muted">
                    Sin observaciones.
                </span>
            }
            else
            {
                @Model.ObservacionesDirector
            }

        </div>

    </div>

    @if (ViewBag.Observaciones != null)
    {
        var observaciones = ViewBag.Observaciones as List<SistemaFarmaciaG6.Models.Observacione>;

        if (observaciones.Any())
        {
            <div class="card border-danger mb-3">

                <div class="card-header bg-danger text-white">
                    Observaciones de Decanatura
                </div>

                <div class="card-body">

                    @foreach (var obs in observaciones)
                    {
                        <div class="border rounded p-3 mb-3">

                            <strong>
                                @(obs.TipoObservacion ?? "Observación")
                            </strong>

                            <br />

                            <small class="text-muted">
                                @obs.Fecha.ToString("dd/MM/yyyy HH:mm")
                            </small>

                            <hr />

                            <p class="mb-0">
                                @obs.Comentario
                            </p>

                        </div>
                    }

                </div>

            </div>
        }
    }

    <a asp-action="Index"
       class="btn btn-secondary">
        Volver
    </a>

    @if (Model.IdEstado == 1 || Model.IdEstado == 3)
    {
        <a asp-action="Edit"
           asp-route-id="@Model.IdInformeDireccion"
           class="btn btn-warning">
            Editar
        </a>
    }

</div>