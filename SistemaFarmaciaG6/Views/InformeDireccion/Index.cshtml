@model IEnumerable<SistemaFarmaciaG6.Models.InformeDireccion>

@{
    ViewData["Title"] = "Informe de Dirección";
    var rolUsuario = Context.Session.GetString("Rol") ?? "";
}

<div class="container-fluid">

    <div class="categorias-section">

        <h2 class="mb-3">
            Informes de Dirección
        </h2>

        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success">
                @TempData["Exito"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        @if (rolUsuario == "Director" || rolUsuario == "Administrador")
        {
            <p>
                <a asp-action="Create"
                   class="btn btn-create">
                    ➕ Generar Informe Dirección
                </a>
            </p>
        }

    </div>

    <table class="table table-hover shadow-sm categorias-table">

        <thead>
            <tr>
                <th>Año</th>
                <th>Director</th>
                <th>Estado</th>
                <th>Fecha Creación</th>
                <th>Fecha Envío</th>
                <th>Fecha Aprobación</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        @item.Anio
                    </td>

                    <td>
                        @item.IdUsuarioNavigation?.Nombre
                        @item.IdUsuarioNavigation?.Apellido1
                        @item.IdUsuarioNavigation?.Apellido2
                    </td>

                    <td>
                        @if (item.IdEstado == 1)
                        {
                            <span class="badge bg-secondary">
                                Borrador
                            </span>
                        }
                        else if (item.IdEstado == 2)
                        {
                            <span class="badge bg-warning text-dark">
                                Pendiente
                            </span>
                        }
                        else if (item.IdEstado == 3)
                        {
                            <span class="badge bg-danger">
                                Devuelto
                            </span>
                        }
                        else if (item.IdEstado == 4)
                        {
                            <span class="badge bg-success">
                                Aprobado
                            </span>
                        }
                        else if (item.IdEstado == 5)
                        {
                            <span class="badge bg-primary">
                                Finalizado
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                @item.IdEstadoNavigation?.NombreEstado
                            </span>
                        }
                    </td>

                    <td>
                        @item.FechaCreacion.ToString("dd/MM/yyyy")
                    </td>

                    <td>
                        @(item.FechaEnvio?.ToString("dd/MM/yyyy HH:mm") ?? "No enviado")
                    </td>

                    <td>
                        @(item.FechaAprobacion?.ToString("dd/MM/yyyy HH:mm") ?? "No aprobado")
                    </td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.IdInformeDireccion"
                           class="btn btn-info btn-sm">
                            Ver
                        </a>

                        @if (item.IdEstado == 1 || item.IdEstado == 3)
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.IdInformeDireccion"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <form asp-action="Enviar"
                                  asp-route-id="@item.IdInformeDireccion"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-success btn-sm">
                                    Enviar
                                </button>

                            </form>
                        }

                        @if (item.IdEstado == 1)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@item.IdInformeDireccion"
                               class="btn btn-danger btn-sm">
                                Eliminar
                            </a>
                        }

                        @if (rolUsuario == "Administrador" &&
                                            (item.IdEstado == 2 || item.IdEstado == 4 || item.IdEstado == 5))
                        {
                            <form asp-action="Reabrir"
                                  asp-route-id="@item.IdInformeDireccion"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-danger btn-sm">
                                    Reabrir
                                </button>

                            </form>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>