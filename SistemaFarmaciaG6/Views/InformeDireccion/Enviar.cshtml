@model SistemaFarmaciaG6.Models.InformeDireccion

@{
    ViewData["Title"] = "Confirmar envío";
}

<div class="container mt-4">

    <div class="card shadow border-success">

        <div class="card-header bg-success text-white">
            Confirmar envío
        </div>

        <div class="card-body">

            <h4 class="text-success">
                ¿Desea enviar este informe?
            </h4>

            <p>
                Una vez enviado, no podrá editarlo nuevamente hasta que sea devuelto.
            </p>

            <hr />

            <p>
                <strong>Año:</strong>
                @Model.Anio
            </p>

            <p>
                <strong>Estado actual:</strong>
                @Model.IdEstadoNavigation?.NombreEstado
            </p>

            <p>
                <strong>Fecha de creación:</strong>
                @Model.FechaCreacion.ToString("dd/MM/yyyy")
            </p>

            @if (Model.FechaEnvio != null)
            {
                <p>
                    <strong>Fecha de envío:</strong>
                    @Model.FechaEnvio?.ToString("dd/MM/yyyy HH:mm")
                </p>
            }

            <form asp-action="Enviar" method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       value="@Model.IdInformeDireccion" />

                <button type="submit"
                        class="btn btn-success">
                    Sí, enviar
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>

    </div>

</div>
