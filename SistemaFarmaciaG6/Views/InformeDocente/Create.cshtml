                                   id="CantidadDocencia"
                                   name="CantidadDocencia"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetalleDocencia"
                                      name="DetalleDocencia"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naDocencia">

                        <label class="form-check-label"
                               for="naDocencia">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Publicaciones por año
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
                                   min="0"
                                   id="CantidadPublicaciones"
                                   name="CantidadPublicaciones"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetallePublicaciones"
                                      name="DetallePublicaciones"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naPublicaciones">

                        <label class="form-check-label"
                               for="naPublicaciones">

