                            </label>

                            <textarea id="DetalleInvestigacion"
                                      name="DetalleInvestigacion"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naInvestigacion">

                        <label class="form-check-label"
                               for="naInvestigacion">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Participación en proyectos de docencia
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
