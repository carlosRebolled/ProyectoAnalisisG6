                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Participación de cursos de grado (Otra Carrera)
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

