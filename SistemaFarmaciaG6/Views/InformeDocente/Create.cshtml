@using SistemaFarmaciaG6.Models

@{
    ViewData["Title"] = "Crear Informe Docente";

    var usuario = ViewBag.Usuario as Usuario;
}

<div class="container mt-4">

    <h2 class="mb-4">
        Crear Informe Docente
    </h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">

            @TempData["Error"]

        </div>
    }

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">

            @TempData["Exito"]

        </div>
    }

    <div class="card shadow-sm">

        <div class="card-header bg-secondary text-white">
            Datos Generales
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Nombre Completo</label>
                    <input class="form-control"
                           readonly
                           value="@($"{usuario.Nombre} {usuario.Apellido1} {usuario.Apellido2}")" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Cédula</label>
                    <input class="form-control"
                           readonly
                           value="@usuario.Cedula" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Correo</label>
                    <input class="form-control"
                           readonly
                           value="@usuario.Correo" />
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Edad</label>
                    <input class="form-control"
                           readonly
                           value="@ViewBag.Edad años" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Género</label>
                    <input class="form-control"
                           readonly
                           value="@usuario.IdGeneroNavigation.NombreGenero" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Departamento</label>
                    <input class="form-control"
                           readonly
                           value="@usuario.IdDepartamentoNavigation.NombreDepartamento" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Categoría</label>
                    <input class="form-control"
                           readonly
                           value="@usuario.IdCategoriaNavigation.NombreCategoria" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Tipo Nombramiento</label>
                    <input class="form-control"
                           readonly
                           value="@usuario.IdTipoNombramientoNavigation.NombreNombramiento" />
                </div>

            </div>

        </div>

        <div class="card shadow-sm mb-4">

            <div class="card-header">
                Información del Informe
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="fw-bold">
                            Año del Informe
                        </label>

                        <input type="text"
                               class="form-control"
                               value="@DateTime.Now.Year"
                               readonly />

                        <input type="hidden"
                               name="Anio"
                               value="@DateTime.Now.Year" />

                    </div>

                </div>

            </div>

        </div>

        <form id="formInformeDocente" asp-action="Create" method="post">

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Participación en Congresos Activos
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
                                   min="0"
                                   id="CantidadCongresosActivos"
                                   name="CantidadCongresosActivos"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetalleCongresosActivos"
                                      name="DetalleCongresosActivos"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naCongresosActivos">

                        <label class="form-check-label"
                               for="naCongresosActivos">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Participación en Congresos Pasivos
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
                                   min="0"
                                   id="CantidadCongresosPasivos"
                                   name="CantidadCongresosPasivos"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetalleCongresosPasivos"
                                      name="DetalleCongresosPasivos"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naCongresosPasivos">

                        <label class="form-check-label"
                               for="naCongresosPasivos">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>



            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Participación en proyectos de acción social
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
                                   min="0"
                                   id="CantidadAccionSocial"
                                   name="CantidadAccionSocial"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetalleAccionSocial"
