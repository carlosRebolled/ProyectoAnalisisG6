                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Participación en cursos de posgrado o TFG
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
                                   min="0"
                                   id="CantidadPosgrado"
                                   name="CantidadPosgrado"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetallePosgrado"
                                      name="DetallePosgrado"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naPosgrado">

                        <label class="form-check-label"
                               for="naPosgrado">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        Representación fuera de la Facultad
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">

                            <label class="form-label">
                                Cantidad
                            </label>

                            <input type="number"
                                   min="0"
                                   id="CantidadRepresentacion"
                                   name="CantidadRepresentacion"
                                   class="form-control" />

                        </div>

                        <div class="col-md-9">

                            <label class="form-label">
                                Detalle
                            </label>

                            <textarea id="DetalleRepresentacion"
                                      name="DetalleRepresentacion"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                    </div>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naRepresentacion">

                        <label class="form-check-label"
                               for="naRepresentacion">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    Otros
                </div>

                <div class="card-body">

                    <label class="form-label">
                        Detalle
                    </label>

                    <textarea id="DetalleOtros"
                              class="form-control"
                              rows="4"
                              name="DetalleOtros"></textarea>

                    <div class="form-check mt-3">

                        <input class="form-check-input"
                               type="checkbox"
                               id="naOtros">

                        <label class="form-check-label"
                               for="naOtros">

                            No aplica

                        </label>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm mb-4">

                <div class="card-header">
                    Observaciones del Docente
                </div>

                <div class="card-body">

                    <textarea id="ObservacionesDocente"
                              class="form-control"
                              rows="6"
                              name="ObservacionesDocente"
                              placeholder="Ingrese observaciones adicionales si lo considera necesario"></textarea>

                </div>

            </div>

            <div class="text-center mt-4 mb-5">
                <button type="submit" class="btn btn-create">
                    Guardar Borrador
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>
            </div>

        </form>

        @section Scripts{

            <script>

                        document.getElementById("naCongresosActivos")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadCongresosActivos");
                            let detalle = document.getElementById("DetalleCongresosActivos");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naCongresosPasivos")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadCongresosPasivos");
                            let detalle = document.getElementById("DetalleCongresosPasivos");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naAccionSocial")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadAccionSocial");
                            let detalle = document.getElementById("DetalleAccionSocial");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naInvestigacion")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadInvestigacion");
                            let detalle = document.getElementById("DetalleInvestigacion");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naDocencia")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadDocencia");
                            let detalle = document.getElementById("DetalleDocencia");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naPublicaciones")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadPublicaciones");
                            let detalle = document.getElementById("DetallePublicaciones");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naCursosGrado")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadCursosGrado");
                            let detalle = document.getElementById("DetalleCursosGrado");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naPosgrado")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadPosgrado");
                            let detalle = document.getElementById("DetallePosgrado");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                        document.getElementById("naRepresentacion")
                        .addEventListener("change", function () {

                            let cantidad = document.getElementById("CantidadRepresentacion");
                            let detalle = document.getElementById("DetalleRepresentacion");

                            if (this.checked) {

                                cantidad.value = 0;
                                detalle.value = "N/A";

                                cantidad.readOnly = true;
                                detalle.readOnly = true;

                            }
                            else {

                                cantidad.readOnly = false;
                                detalle.readOnly = false;

                                cantidad.value = "";
                                detalle.value = "";

                            }

                        });

            </script>

            <script>

                document.getElementById("naOtros")
                .addEventListener("change", function () {

                let detalle = document.getElementById("DetalleOtros");

                if (this.checked) {

                detalle.value = "N/A";
                detalle.readOnly = true;

                }
                else {

                detalle.value = "";
                detalle.readOnly = false;

                }

                });

            </script>
            
        }
        <script>

                    document.addEventListener("DOMContentLoaded", function () {

                        const formulario =
                            document.getElementById("formInformeDocente");

                        const campos =
                            formulario.querySelectorAll("input, textarea");

                        campos.forEach(campo => {

                            let valorGuardado =
                                localStorage.getItem(campo.name);

                            if (valorGuardado !== null)
                            {
                                campo.value = valorGuardado;
                            }

                        });

                        campos.forEach(campo => {

                            campo.addEventListener("input", function () {

                                localStorage.setItem(
                                    campo.name,
                                    campo.value
                                );

                            });

                        });

                    });

        </script>

        @if (TempData["LimpiarLocalStorage"] != null)
        {
            <script>

                        localStorage.clear();

            </script>
        }

    </div>

</div>



