        <div class="text-center mt-4 mb-5">

            <button type="submit"
                    class="btn btn-warning">
                Guardar Cambios
            </button>

            <a asp-action="Details"
               asp-route-id="@Model.IdInformeDocente"
               class="btn btn-info">
                Ver Detalle
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancelar
            </a>

        </div>

    </form>

</div>

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function () {

            configurarNoAplica(
                "naCongresosActivos",
                "CantidadCongresosActivos",
                "DetalleCongresosActivos"
            );

            configurarNoAplica(
                "naCongresosPasivos",
                "CantidadCongresosPasivos",
                "DetalleCongresosPasivos"
            );

            configurarNoAplica(
                "naAccionSocial",
                "CantidadAccionSocial",
                "DetalleAccionSocial"
            );

            configurarNoAplica(
                "naInvestigacion",
                "CantidadInvestigacion",
                "DetalleInvestigacion"
            );

            configurarNoAplica(
                "naDocencia",
                "CantidadDocencia",
                "DetalleDocencia"
            );

            configurarNoAplica(
                "naPublicaciones",
                "CantidadPublicaciones",
                "DetallePublicaciones"
            );

            configurarNoAplica(
                "naCursosGrado",
                "CantidadCursosGrado",
                "DetalleCursosGrado"
            );

            configurarNoAplica(
                "naPosgrado",
                "CantidadPosgrado",
                "DetallePosgrado"
            );

            configurarNoAplica(
                "naRepresentacion",
                "CantidadRepresentacion",
                "DetalleRepresentacion"
            );

            configurarNoAplicaSoloDetalle(
                "naOtros",
                "DetalleOtros"
            );

        });

        function configurarNoAplica(idCheck, idCantidad, idDetalle) {

            let check = document.getElementById(idCheck);
            let cantidad = document.getElementById(idCantidad);
            let detalle = document.getElementById(idDetalle);

            function actualizar() {

                if (check.checked) {

                    cantidad.value = 0;
                    detalle.value = "N/A";

                    cantidad.readOnly = true;
                    detalle.readOnly = true;

                }
                else {

                    cantidad.readOnly = false;
                    detalle.readOnly = false;

                    if (detalle.value === "N/A") {
                        detalle.value = "";
                    }

                }

            }

            actualizar();

            check.addEventListener("change", actualizar);

        }

        function configurarNoAplicaSoloDetalle(idCheck, idDetalle) {

            let check = document.getElementById(idCheck);
            let detalle = document.getElementById(idDetalle);

            function actualizar() {

                if (check.checked) {

                    detalle.value = "N/A";
                    detalle.readOnly = true;

                }
                else {

                    detalle.readOnly = false;

                    if (detalle.value === "N/A") {
                        detalle.value = "";
                    }

                }

            }

            actualizar();

            check.addEventListener("change", actualizar);

        }

    </script>

}