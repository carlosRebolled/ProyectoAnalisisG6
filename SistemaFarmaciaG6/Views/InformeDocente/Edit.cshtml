                </div>

                <div class="form-check mt-3">

                    <input class="form-check-input"
                           type="checkbox"
                           id="naDocencia"
                           @(Model.DetalleDocencia == "N/A" ? "checked" : "") />

                    <label class="form-check-label"
                           for="naDocencia">
